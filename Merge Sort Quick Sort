#include<stdio.h>
void quicksort(int a[],int low,int high);
int partition(int a[],int low,int high);


#include"quick.h"
void quicksort(int a[],int low,int high)
{
   int p;
   if(low<high)
   {
      p=partition(a,low,high);
      quicksort(a,low,p-1);
      quicksort(a,p+1,high);
   }
}
int partition(int a[],int low,int high){
   int pivot=a[low];
   int i=low+1,j=high,temp;
   while(i<=j)
   {
      while(a[i]<=pivot&&i<=high)
         i++;
      while(a[i]>pivot)
         j--;
      if(i<j){
         temp=a[i];
         a[i]=a[j];
         a[j]=temp;
      }
   }
   temp=a[low];
   a[low]=a[j];
   a[j]=temp;
   return j;
}

