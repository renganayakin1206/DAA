#include <iostream>

using namespace std;


const int INF = 9999;
const int MAX = 20;


void printMatrix(int D[MAX][MAX], int n) {
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (D[i][j] >= INF)
                cout << "INF\t";
            else
                cout << D[i][j] << "\t";
        }
        cout << endl;
    }
}

int main() {
    int n, e;
    int D[MAX][MAX];


    cout << "Enter number of vertices: ";
    cin >> n;


    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i == j) D[i][j] = 0;
            else D[i][j] = INF;
        }
    }

    cout << "Enter number of edges: ";
    cin >> e;

    cout << "Enter edges (source destination weight):" << endl;
    for (int i = 0; i < e; i++) {
        int u, v, w;
        cin >> u >> v >> w;


        if (u >= 1 && u <= n && v >= 1 && v <= n) {
            D[u - 1][v - 1] = w;
        } else {
            cout << "Invalid vertex! Skip edge." << endl;
        }
    }

    cout << "\nInitial D(0) Matrix:" << endl;
    printMatrix(D, n);


    for (int k = 0; k < n; k++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {

                if (D[i][k] + D[k][j] < D[i][j]) {
                    D[i][j] = D[i][k] + D[k][j];
                }
            }
        }


        cout << "\nD(" << k + 1 << ") After vertex " << k + 1 << " as intermediate:" << endl;
        printMatrix(D, n);
    }

    return 0;
}



