#include <iostream>
using namespace std;

const int MAX = 100;

int main() {
    int n;

    cout << "Enter number of characters: ";
    cin >> n;

    char data[MAX];
    int freq[MAX];

    cout << "Enter characters:\n";
    for (int i = 0; i < n; i++) cin >> data[i];

    cout << "Enter frequencies:\n";
    for (int i = 0; i < n; i++) cin >> freq[i];

    int parent[MAX];
    for (int i = 0; i < MAX; i++) parent[i] = -1;

    int size = n;
    int step = 1;

    cout << "\n--- Huffman Construction Steps ---\n";

    while (1) {
        int min1 = -1, min2 = -1;

        // Find two smallest
        for (int i = 0; i < size; i++) {
            if (freq[i] == -1) continue;

            if (min1 == -1 || freq[i] < freq[min1]) {
                min2 = min1;
                min1 = i;
            }
            else if (min2 == -1 || freq[i] < freq[min2]) {
                min2 = i;
            }
        }

        if (min2 == -1) break;

        // Print step
        cout << "\nStep " << step++ << ": ";
        cout << "Combine ";

        if (min1 < n) cout << data[min1] << "(" << freq[min1] << ")";
        else cout << freq[min1];

        cout << " + ";

        if (min2 < n) cout << data[min2] << "(" << freq[min2] << ")";
        else cout << freq[min2];

        // Combine
        freq[size] = freq[min1] + freq[min2];

        cout << " = " << freq[size] << endl;

        parent[min1] = size;
        parent[min2] = size;

        freq[min1] = -1;
        freq[min2] = -1;

        size++;
    }

    // Print Huffman Codes
    cout << "\n--- Huffman Codes ---\n";

    for (int i = 0; i < n; i++) {
        cout << data[i] << ": ";

        int code[MAX], top = 0;
        int j = i;

        while (parent[j] != -1) {
            if (j % 2 == 0)
                code[top++] = 0;
            else
                code[top++] = 1;

            j = parent[j];
        }

        for (int k = top - 1; k >= 0; k--)
            cout << code[k];

        cout << endl;
    }

    return 0;
}

