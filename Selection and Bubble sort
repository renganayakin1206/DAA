#include"bubhead.h"
void bubble_sort(int A[],int n){
   int i,j,k,t;
   for(i=0;i<=n-2;i++){
      for(j=0;j<=n-2-i;j++){
         if (A[j]>A[j+1]){
            t=A[j];
            A[j]=A[j+1];
            A[j+1]=t;
            printf("Pass no:%d\n",i+1);
            for(k=0;k<n;k++){
               printf("%d ",A[k]);
            }
            printf("\n");
         }
      }
   }
      printf("After sorting:");
      for(i=0;i<n;i++){
         printf("%d ",A[i]);
      }
      printf("\n");
}
